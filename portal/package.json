{
  "name": "portal",
  "version": "1.0.0",
  "description": "trackmyweek.com portal — SSO, dashboard, admin",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "jest tests/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:e2e": "playwright test"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "../core/auth/*.js",
      "server.js"
    ],
    "coverageThresholds": {
      "../core/auth/auth.js": {
        "branches": 100,
        "functions": 100,
        "lines": 90
      },
      "../core/auth/middleware.js": {
        "branches": 100,
        "functions": 100,
        "lines": 100
      }
    }
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "@playwright/test": "^1.42.0"
  }
}
